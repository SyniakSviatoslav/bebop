# Dependencies
node_modules/

# Build / cache
*.tsbuildinfo
.DS_Store

# Bebop runtime state (NEVER commit your local memory / vault / sync DB)
.bebop/
memory.json
*.vault.json
*.sqlite
*.db

# Logs
*.log

# Env / secrets — Bebop NEVER reads cloud keys from files; keep them out of the repo
.env
.env.*
*.pem
*.key

# Rust build artifacts (keep the wasm binary src/bebop_core.wasm committed; never commit target/)
crates/*/target/
**/target/

# Python venvs (do NOT commit — multi-GB)
.venv/
.venv2/
.venv-render/

# Headless-browser download (used only to verify p5 sketches; multi-hundred-MB)
chrome/

# Scratch recorder/renderer scripts for footage (kept out of the repo)
record-session.py
record-any.py
render-cast.py
capture-lounge.cjs
docs/footage/*.cast.tmp

# Build output
dist/

# pnpm lockfile (this repo is npm-based; package-lock.json is the source of truth)
pnpm-lock.yaml
pnpm-workspace.yaml
.review/
